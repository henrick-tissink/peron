# URL of the Peron backend API. Used both server-side (SSR fetches) and client-side (FareMatrix).
# Dev default (same host, port 3001): http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional server-side override (takes precedence over NEXT_PUBLIC_API_URL in Node SSR).
# Leave unset in most cases.
# API_URL=

# Server-side Sentry DSN (peron-web project)
SENTRY_DSN_WEB=
# Client-side DSN (same project — Next requires NEXT_PUBLIC_ prefix to ship to browser)
NEXT_PUBLIC_SENTRY_DSN_WEB=
# Source-map upload at build time
SENTRY_ORG=
SENTRY_AUTH_TOKEN=
# Set by Coolify on each deploy (release tagging)
GIT_COMMIT_SHA=
